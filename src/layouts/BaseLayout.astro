		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<slot name="head" />
	</head>
	<body>
		<Navbar client:load />
		<slot />
		<Footer />
	</body>
</html>

