---
import { getEntry, render } from "astro:content";
import MDContainer from "src/components/MDContainer.astro";
import { Box, Center, Stack } from "styled-system/jsx";
import { BorderBeam } from "~/components/mystic/BorderBeam";
import { TermViewCommand } from "~/components/ui/TermViewCommand";
import Layout from "~/layouts/BaseLayout.astro";
import { isTextAgent } from "~/utils/detect-text-agent";
import { lip } from "~/utils/lipgloss";
const entry = await getEntry("pages", "index");

if (!entry) {
	return Astro.redirect("/404");
}

if (isTextAgent(Astro.request)) {
	return new Response(lip.RenderMD(entry.body), {
		headers: Astro.response.headers,
	});
}

const { Content } = await render(entry);
---

<Layout>
	<Center class="banner">
		<Stack align="center">
			<h1 class="title">TCM</h1>
			<Box position="relative" px="4" py="2" backgroundColor="bg.canvas">
				<TermViewCommand client:idle value={Astro.url.href} />
				<BorderBeam size={64} />
			</Box>
			<br />
		</Stack>
	</Center>
	<MDContainer>
		<Content />
	</MDContainer>
</Layout>

<style>
	.title {
		text-align: center;
		font-size: max(150px, 24vw);
		line-height: 1em;
		user-select: none;
		color: #c792ea;
		text-shadow:
			4px 0 6px #f07178,
			-4px 0 6px #82aaff;
	}

	.banner {
		position: relative;
	}

	.banner::before {
		content: "";
		display: block;
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;

		background: linear-gradient(
				rgba(18, 16, 16, 0) 50%,
				rgba(0, 0, 0, 0.25) 50%
			),
			linear-gradient(
				90deg,
				rgba(255, 0, 0, 0.06),
				rgba(0, 255, 0, 0.02),
				rgba(0, 0, 255, 0.06)
			);
		background-size:
			100% 2px,
			3px 100%;
	}

	@keyframes border-beam {
		100% {
			offset-distance: 100%;
		}
	}
</style>
